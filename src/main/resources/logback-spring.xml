<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Lee log.path desde Spring Environment (soporta env var LOG_PATH via relaxed binding) -->
    <springProperty name="LOG_PATH" source="log.path" defaultValue="/var/log/app"/>
    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="dm-api"/>

    <!-- ==========================================
         CONSOLE: texto legible para desarrollo
    ========================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ==========================================
         FILE: JSON estructurado para Promtail/Loki
         Ejemplo de línea generada:
         {"@timestamp":"...","level":"INFO","app":"dm-api",
          "logger_name":"com.dmBackend...","message":"..."}
    ========================================== -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/app.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/app-%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>

        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- campo fijo para identificar la app en Loki -->
            <customFields>{"app":"${APP_NAME}"}</customFields>
            <!-- no incluir stack trace como objeto separado, va dentro de message -->
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerCause>20</maxDepthPerCause>
                <rootCauseFirst>true</rootCauseFirst>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- Reducir ruido de Keycloak/Hibernate en los logs -->
    <logger name="org.keycloak" level="WARN"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="JSON_FILE"/>
    </root>

</configuration>